ACME_EMAIL=name@email.com
TRAEFIK_DASHBOARD_HOST=traefik.site.com.br

# Para testar TLS sem estourar o rate limit do Let's Encrypt, descomente a
# linha abaixo (CA de staging). Esvazie traefik/acme/acme.json ao alternar
# entre staging e produção. Deixar comentado = CA de produção (default).
# ACME_CASERVER=https://acme-staging-v02.api.letsencrypt.org/directory
